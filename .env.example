# Copy this file to `.env` and fill in one or more keys. The .env loader does
# NOT override real environment variables, so `export GEMINI_API_KEY=...` wins.

# Tip: run `ofo --login` for a guided, browser-assisted setup of the keys below.

# Zero-price model catalogue where available:
OPENROUTER_API_KEY=

# Major providers (their own free credits / free tiers; API keys, not OAuth):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MOONSHOT_API_KEY=
PERPLEXITY_API_KEY=

# Free API tier / quota-backed providers:
HUGGINGFACE_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
REPLICATE_API_TOKEN=

# Moonshot/Kimi China accounts use a different base URL:
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Optional: restrict providers globally. You can also pass --providers.
# OFO_PROVIDERS=openrouter,gemini,huggingface,together,fireworks,replicate

# Optional: add/override fallback models when a provider catalogue is unavailable.
# Format: model,model|context,model|context|display name
# TOGETHER_MODELS=meta-llama/Llama-3.3-70B-Instruct-Turbo|131072|Llama 3.3 70B
